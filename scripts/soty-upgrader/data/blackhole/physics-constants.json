  "isco": {
    "description": "Innermost Stable Circular Orbit — the smallest stable orbit for massive particles",
    "schwarzschild": {
      "formula": "r_ISCO = 3 R_s = 6GM/c²",
      "formulaLatex": "r_{ISCO} = 6M = 3R_s",
      "naturalUnitsFormula": "r_ISCO = 6M",
      "ratioToRs": 3.0,
      "specificEnergy": 0.9428,
      "specificAngularMomentum_over_M": 3.4641,
      "orbitalFrequency_formula": "f = c³/(6√6 × 2πGM)",
      "bindingEnergy_percent": 5.719,
      "note": "The binding energy at ISCO determines the maximum radiative efficiency of a non-spinning black hole"
    },
    "kerr": {
      "progradeFormula": "r_ISCO = M(3 + Z2 - √((3-Z1)(3+Z1+2Z2))) where Z1 = 1+(1-a²)^(1/3)[(1+a)^(1/3)+(1-a)^(1/3)], Z2 = √(3a²+Z1²)",
