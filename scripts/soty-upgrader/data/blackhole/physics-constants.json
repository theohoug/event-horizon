    "outerBoundaryLatex": "r_{ergo} = M + \\sqrt{M^2 - a^2\\cos^2\\theta}",
    "innerBoundaryFormula": "r_+ = M + √(M² - a²)",
    "innerBoundaryLatex": "r_+ = M + \\sqrt{M^2 - a^2}",
    "equatorialExtent": {
      "description": "At the equator (θ=π/2), the ergosphere extends from r_+ to r=2M regardless of spin",
      "outerRadius_over_M": 2.0,
      "note": "At the equator, r_ergo = 2M always"
    },
    "polarExtent": {
